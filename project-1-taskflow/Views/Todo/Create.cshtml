@model project_1_taskflow.Models.TodoItem

@{
    ViewData["Title"] = "Thêm Task mới";
}

<h2>➕ Thêm Task mới</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Tiêu đề *</label>
                <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề task..." />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả chi tiết (tùy chọn)"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="DueDate" class="form-label">Ngày hết hạn</label>
                <input asp-for="DueDate" class="form-control" type="date" />
            </div>

            <div class="mb-3">
                <label asp-for="Priority" class="form-label">Mức ưu tiên</label>
                <select asp-for="Priority" class="form-select"
                        asp-items="@Html.GetEnumSelectList<project_1_taskflow.Models.Priority>()">
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">Trạng thái</label>
                <select asp-for="Status" class="form-select"
                        asp-items="@Html.GetEnumSelectList<project_1_taskflow.Models.TodoStatus>()">
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Danh mục</label>
                <select asp-for="CategoryId" class="form-select">
                    <option value="">-- Chọn danh mục --</option>
                    @if (ViewBag.Categories != null)
                    {
                        @foreach (SelectListItem item in ViewBag.Categories)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">💾 Lưu Task</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
