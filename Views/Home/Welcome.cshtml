@{
    ViewData["Title"] = "TaskFlow - Quản lý công việc";
}

<div class="text-center py-5">
    <h1>✅ TaskFlow</h1>
    <p class="lead">Ứng dụng quản lý công việc cá nhân đơn giản</p>
    <hr />
    <p>Đăng ký tài khoản hoặc đăng nhập để bắt đầu quản lý công việc của bạn.</p>
    <div class="mt-4">
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg me-2">Đăng ký ngay</a>
        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg">Đăng nhập</a>
    </div>

    <div class="row mt-5">
        <div class="col-md-4">
            <h4>📝 Tạo Tasks</h4>
            <p>Tạo công việc mới với tiêu đề, mô tả, deadline và mức ưu tiên.</p>
        </div>
        <div class="col-md-4">
            <h4>🗂️ Phân loại</h4>
            <p>Sắp xếp tasks theo danh mục: Công việc, Cá nhân, Học tập...</p>
        </div>
        <div class="col-md-4">
            <h4>📊 Theo dõi</h4>
            <p>Dashboard hiển thị tổng quan tiến độ công việc của bạn.</p>
        </div>
    </div>
</div>
