@{
    ViewData["Title"] = "Dashboard";
}

<h2>📊 Dashboard</h2>
<hr />

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center" style="border-left: 4px solid #3498db;">
            <div class="card-body">
                <h3>@ViewBag.TotalTasks</h3>
                <p class="text-muted">Tổng Tasks</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center" style="border-left: 4px solid #f39c12;">
            <div class="card-body">
                <h3>@ViewBag.PendingTasks</h3>
                <p class="text-muted">Chờ xử lý</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center" style="border-left: 4px solid #e74c3c;">
            <div class="card-body">
                <h3>@ViewBag.InProgressTasks</h3>
                <p class="text-muted">Đang làm</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center" style="border-left: 4px solid #2ecc71;">
            <div class="card-body">
                <h3>@ViewBag.CompletedTasks</h3>
                <p class="text-muted">Hoàn thành</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-warning text-dark">
        ⏰ Tasks sắp hết hạn (trong 3 ngày tới)
    </div>
    <div class="card-body">
        @if (ViewBag.UpcomingTasks != null && ((List<project_1_taskflow.Models.TodoItem>)ViewBag.UpcomingTasks).Count > 0)
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Task</th>
                        <th>Danh mục</th>
                        <th>Hạn</th>
                        <th>Ưu tiên</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in (List<project_1_taskflow.Models.TodoItem>)ViewBag.UpcomingTasks)
                    {
                        <tr>
                            <td>@task.Title</td>
                            <td>
                                @if (task.Category != null)
                                {
                                    <span class="badge" style="background-color: @task.Category.Color">@task.Category.Name</span>
                                }
                            </td>
                            <td>@task.DueDate?.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (task.Priority == project_1_taskflow.Models.Priority.High)
                                {
                                    <span class="badge bg-danger">Cao</span>
                                }
                                else if (task.Priority == project_1_taskflow.Models.Priority.Medium)
                                {
                                    <span class="badge bg-warning text-dark">Trung bình</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Thấp</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Không có task nào sắp hết hạn. 🎉</p>
        }
    </div>
</div>

<div class="text-center mt-4">
    <a asp-controller="Todo" asp-action="Index" class="btn btn-primary">Xem tất cả công việc →</a>
    <a asp-controller="Todo" asp-action="Create" class="btn btn-outline-success">+ Thêm task mới</a>
</div>
