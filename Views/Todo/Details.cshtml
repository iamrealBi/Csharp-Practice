@model project_1_taskflow.Models.TodoItem

@{
    ViewData["Title"] = "Chi tiết Task";
}

<h2>🔍 Chi tiết Task</h2>
<hr />

<div class="card">
    <div class="card-body">
        <h4 class="card-title">@Model.Title</h4>

        <table class="table table-borderless" style="max-width: 500px;">
            <tr>
                <th>Mô tả:</th>
                <td>@(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)</td>
            </tr>
            <tr>
                <th>Danh mục:</th>
                <td>
                    @if (Model.Category != null)
                    {
                        <span class="badge" style="background-color: @Model.Category.Color">@Model.Category.Name</span>
                    }
                    else
                    {
                        <span class="text-muted">Không có</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Ưu tiên:</th>
                <td>
                    @if (Model.Priority == project_1_taskflow.Models.Priority.High)
                    {
                        <span class="badge bg-danger">🔴 Cao</span>
                    }
                    else if (Model.Priority == project_1_taskflow.Models.Priority.Medium)
                    {
                        <span class="badge bg-warning text-dark">🟡 Trung bình</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">⚪ Thấp</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Trạng thái:</th>
                <td>
                    @if (Model.Status == project_1_taskflow.Models.TodoStatus.Pending)
                    {
                        <span class="badge bg-secondary">⬜ Chờ xử lý</span>
                    }
                    else if (Model.Status == project_1_taskflow.Models.TodoStatus.InProgress)
                    {
                        <span class="badge bg-primary">🔄 Đang làm</span>
                    }
                    else
                    {
                        <span class="badge bg-success">✅ Hoàn thành</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Hạn:</th>
                <td>@(Model.DueDate.HasValue ? Model.DueDate.Value.ToString("dd/MM/yyyy") : "Không có deadline")</td>
            </tr>
            <tr>
                <th>Ngày tạo:</th>
                <td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">✏️ Sửa</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">🗑️ Xóa</a>
    <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
</div>
