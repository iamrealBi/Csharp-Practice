@model IEnumerable<project_1_taskflow.Models.TodoItem>

@{
    ViewData["Title"] = "Công việc của tôi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📋 Công việc của tôi</h2>
    <a asp-action="Create" class="btn btn-success">+ Thêm task mới</a>
</div>

@if (Model.Any())
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Trạng thái</th>
                <th>Tiêu đề</th>
                <th>Danh mục</th>
                <th>Ưu tiên</th>
                <th>Hạn</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.Status == project_1_taskflow.Models.TodoStatus.Completed ? "table-success" : "")">
                    <td>
                        <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" style="display:inline;">
                            @if (item.Status == project_1_taskflow.Models.TodoStatus.Pending)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Chờ xử lý">⬜</button>
                            }
                            else if (item.Status == project_1_taskflow.Models.TodoStatus.InProgress)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-primary" title="Đang làm">🔄</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-outline-success" title="Hoàn thành">✅</button>
                            }
                        </form>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="text-decoration-none @(item.Status == project_1_taskflow.Models.TodoStatus.Completed ? "text-decoration-line-through text-muted" : "")">
                            @item.Title
                        </a>
                    </td>
                    <td>
                        @if (item.Category != null)
                        {
                            <span class="badge" style="background-color: @item.Category.Color">
                                @item.Category.Name
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Không có</span>
                        }
                    </td>
                    <td>
                        @if (item.Priority == project_1_taskflow.Models.Priority.High)
                        {
                            <span class="badge bg-danger">🔴 Cao</span>
                        }
                        else if (item.Priority == project_1_taskflow.Models.Priority.Medium)
                        {
                            <span class="badge bg-warning text-dark">🟡 Trung bình</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">⚪ Thấp</span>
                        }
                    </td>
                    <td>
                        @if (item.DueDate.HasValue)
                        {
                            @if (item.DueDate.Value < DateTime.Now && item.Status != project_1_taskflow.Models.TodoStatus.Completed)
                            {
                                <span class="text-danger fw-bold">⚠️ @item.DueDate.Value.ToString("dd/MM/yyyy")</span>
                            }
                            else
                            {
                                @item.DueDate.Value.ToString("dd/MM/yyyy")
                            }
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="text-center py-5">
        <h4>Chưa có công việc nào</h4>
        <p class="text-muted">Bắt đầu bằng cách tạo task đầu tiên!</p>
        <a asp-action="Create" class="btn btn-primary">+ Tạo task đầu tiên</a>
    </div>
}
